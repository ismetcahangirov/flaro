# ============================================================
# SKETCHFLOW - Environment Variables Template
# Copy this file to .env.local and fill real values.
# ============================================================

# Supabase frontend values (public)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Stripe frontend value (public)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY

# App config
VITE_APP_URL=http://localhost:5173
VITE_APP_VERSION=dev

# Server-side values belong in Supabase secrets, not in VITE_* env vars:
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_URL=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
# ANTHROPIC_API_KEY=
